{
  "name": "sqmap",
  "version": "0.4.5",
  "description": "A lightweight and easy to use micro ORM for TypeScript.",
  "author": "Derefs Software SRL",
  "license": "MIT",
  "main": "./dist/sqmap.js",
  "types": "./dist/sqmap.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sqmap.d.ts",
      "import": "./dist/sqmap.js"
    },
    "./postgres-pg": {
      "types": "./dist/apis/postgres-pg.d.ts",
      "import": "./dist/apis/postgres-pg.js"
    },
    "./sqlite-bun": {
      "types": "./dist/apis/sqlite-bun.d.ts",
      "import": "./dist/apis/sqlite-bun.js"
    }
  },
  "type": "module",
  "files": [
    "dist/",
    "!dist/tests/"
  ],
  "scripts": {
    "build": "rm -rf ./dist && tsc -p . && rm -rf ./dist/tests",
    "test": "node --experimental-specifier-resolution=node --loader ts-node/esm ./tests/index.ts",
    "publish": "npm run build && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/derefs/sqmap.git"
  },
  "bugs": {
    "url": "https://github.com/derefs/sqmap/issues"
  },
  "homepage": "https://github.com/derefs/sqmap",
  "keywords": [
    "sql",
    "orm",
    "postgres"
  ],
  "devDependencies": {
    "@types/bun": "^1.2.20",
    "@types/pg": "^8.6.6",
    "pg": "^8.10.0",
    "ts-node": "^10.9.1"
  }
}
